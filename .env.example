# Modèle de configuration. Copie ce fichier en « .env.local » et remplis les valeurs.
# Pour HÉBERGER LE ROBOT sur un VPS, seules les clés ci-dessous sont nécessaires
# (tu peux aussi simplement copier ton .env.local complet existant : le robot ignore le reste).

# ── File d'attente + commandes (Upstash Redis REST) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Compte La Poste (connexion auto à l'étape paiement) ──
LAPOSTE_EMAIL=
LAPOSTE_PASSWORD=
# Cryptogramme (3 chiffres au dos) de la carte mémorisée — pour l'auto-paiement.
LAPOSTE_CVV=
# 1 = le robot clique « Payer » automatiquement. 0 = il s'arrête avant (tu paies à la main).
RPA_AUTOPAY=1

# ── Liaison avec le site (post de l'étiquette + alertes) ──
# Doit être IDENTIQUE à la variable RPA_API_KEY côté hébergeur du site (Cloudflare).
RPA_API_KEY=
# URL publique du site (où le robot poste l'étiquette + les alertes Telegram).
APP_URL=https://commande.le-laboratoire.workers.dev

# ── Expéditeur (optionnel) ──
SENDER_PHONE=
# Poids par défaut du colis en kg (défaut 0.5 si absent).
DEFAULT_WEIGHT_KG=0.5

# ── Écran déporté (Docker) ──
# Mot de passe pour ouvrir l'écran du serveur via noVNC. METS-EN UN SOLIDE.
VNC_PASSWORD=
